# ── Seller (jellyfin-proxy operator) ────────────────────────────────────────
# Generate a fresh keypair: cargo run --example generate-keys
SELLER_ADDRESS=0xYourSellerAddress
SELLER_PRIVATE_KEY=0xYourSellerPrivateKey

# ── Buyer (CLI payment agent) ────────────────────────────────────────────────
# Generate a second keypair for the buyer
BUYER_ADDRESS=0xYourBuyerAddress
BUYER_PRIVATE_KEY=0xYourBuyerPrivateKey

# ── Arc testnet RPC ──────────────────────────────────────────────────────────
# Obtain via: arc-canteen login && arc-canteen rpc eth_chainId
# Public endpoint: https://rpc.testnet.arc.network
ARC_RPC_URL=https://rpc.testnet.arc.network

# ── MediaAccess smart contract ───────────────────────────────────────────────
# Deploy with: forge script contracts/script/Deploy.s.sol --broadcast \
#   --rpc-url $ARC_RPC_URL --private-key $SELLER_PRIVATE_KEY
MEDIA_ACCESS_CONTRACT=0xYourDeployedMediaAccessAddress

# ── Jellyfin upstream ────────────────────────────────────────────────────────
# The URL of your Jellyfin instance (no trailing slash)
JELLYFIN_URL=http://localhost:8096

# ── Proxy server ─────────────────────────────────────────────────────────────
PORT=3001

# ── SQLite access cache ───────────────────────────────────────────────────────
# The proxy creates the parent directory automatically if it doesn't exist
DATABASE_URL=sqlite://./data/access.db

# ── Per-second streaming billing ─────────────────────────────────────────────
# Rate in atomic USDC units per second (1 USDC = 1_000_000 atomic)
# 100 atomic = $0.0001/sec → $0.001/chunk at 10-second chunks
STREAM_RATE_PER_SEC_ATOMIC=100

# Length of each billed video segment in seconds
STREAM_CHUNK_SECS=10

# ── Buy-to-access (one-time purchase) ────────────────────────────────────────
# Price in atomic USDC units for permanent on-chain access
# 5_000_000 atomic = $5.00 USDC
BUY_PRICE_ATOMIC=5000000
